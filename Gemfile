source "https://rubygems.org"

# Avoids the ActiveSupport 8.x dependency cascade that breaks on the uri gem
gem "activesupport", "~> 7.1.0"

# Standard GitHub Pages setup (automatically loads Jekyll and official plugins)
gem "github-pages", group: :jekyll_plugins

# Required for Ruby 3.0+ (Jekyll needs this to run the local server)
gem "webrick", "~> 1.8"